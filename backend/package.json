{
  "name": "voiddecksafety-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^5.0.0",
    "pg": "^8.19.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.30.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
